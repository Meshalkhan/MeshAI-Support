{
  "name": "meshai-support",
  "private": true,
  "workspaces": ["client", "server"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "install:all": "npm install",
    "build": "npm run build --workspace meshai-support-client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
