# Server / Vercel serverless (api/index.js)
OPENAI_API_KEY=sk-...
# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/meshai_support

# Comma-separated origins for CORS (production: your Vercel URL)
CLIENT_URL=http://localhost:5173

PORT=3001

# Frontend build (optional — leave empty when API is same origin)
# VITE_API_URL=https://your-api.example.com
